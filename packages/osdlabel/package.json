{
  "name": "osdlabel",
  "version": "0.5.0",
  "description": "Framework-agnostic core for the osdlabel image annotation library — types, serialization, pure reducers, constraint computation, and keyboard mapping.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [],
  "author": "Guy Or <guydude1@gmail.com>",
  "license": "BSD-3-Clause",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/ tests/"
  },
  "peerDependencies": {
    "fabric": "catalog:peers",
    "openseadragon": "catalog:peers",
    "valibot": "catalog:"
  },
  "dependencies": {
    "@osdlabel/annotation": "workspace:*",
    "@osdlabel/annotation-context": "workspace:*",
    "@osdlabel/decoration": "workspace:*",
    "@osdlabel/fabric-annotations": "workspace:*",
    "@osdlabel/fabric-osd": "workspace:*",
    "@osdlabel/geometry": "workspace:*",
    "@osdlabel/validation": "workspace:*",
    "@osdlabel/viewer-api": "workspace:*"
  },
  "devDependencies": {
    "@types/openseadragon": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osdlabel/osdlabel.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
