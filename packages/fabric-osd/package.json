{
  "name": "@osdlabel/fabric-osd",
  "version": "0.2.0",
  "description": "Fabric.js and OpenSeaDragon integration layer for osdlabel — canvas overlay and viewport transform.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "author": "Guy Or <guydude1@gmail.com>",
  "license": "BSD-3-Clause",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@osdlabel/annotation": "workspace:*",
    "@osdlabel/decoration": "workspace:*",
    "@osdlabel/fabric-annotations": "workspace:*",
    "@osdlabel/validation": "workspace:*",
    "@osdlabel/viewer-api": "workspace:*"
  },
  "peerDependencies": {
    "fabric": "catalog:",
    "openseadragon": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/openseadragon": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osdlabel/osdlabel.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
