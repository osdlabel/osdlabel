{
  "name": "@osdlabel/validation",
  "version": "0.5.0",
  "description": "Schema-based validation for osdlabel objects built on Valibot.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "author": "Guy Or <guydude1@gmail.com>",
  "license": "BSD-3-Clause",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@osdlabel/annotation": "workspace:*"
  },
  "peerDependencies": {
    "valibot": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:",
    "fabric": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osdlabel/osdlabel.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
